#!/usr/bin/env sh

# Block direct commits to protected branches — use a PR instead.
branch="$(git rev-parse --abbrev-ref HEAD)"
if [ "$branch" = "main" ] || [ "$branch" = "develop" ]; then
	echo "Direct commits to '$branch' are not allowed. Create a feature branch and open a PR."
	exit 1
fi

npx prettier --check '**/*.{js,css,html}'
