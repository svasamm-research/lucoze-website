# Lucoze Website — Production deployment environment
# ===================================================
# Copy to /tmp/lucoze-website.env, fill in values, then generate the compose:
#
#   docker compose \
#     --env-file /tmp/lucoze-website.env \
#     -f deploy/lucoze-website.yaml \
#     config > /tmp/lucoze-website-final.yaml
#
# Upload /tmp/lucoze-website-final.yaml to Dokploy UI (Production-Lucoze-Website project).
# NEVER commit the real env file — it contains infrastructure details.
# ---------------------------------------------------------------------------

CUSTOM_IMAGE=svasamm/lucoze-website
CUSTOM_TAG=latest
PULL_POLICY=always

# Agent VPS private IP — find in Hetzner Cloud Console → VPS → Network tab
AGENT_PRIVATE_IP=CHANGE_ME

# Port exposed on the agent's private network (must be unique per bench on same agent)
BENCH_PORT=CHANGE_ME
