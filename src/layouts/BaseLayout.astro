---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import CountrySelectorModal from "../components/CountrySelectorModal.astro";
import NotServedBanner from "../components/NotServedBanner.astro";
import "../styles/global.css";

interface Props {
	title: string;
	description: string;
	canonical?: string;
	activeLink?: string;
	ctaPlan?: string;
	regionSlug?: string;
	signupEnabled?: boolean;
	showPharmacy?: boolean;
	served?: boolean;
}

const {
	title,
	description,
	canonical = Astro.url.href,
	activeLink = "",
	ctaPlan = "",
	regionSlug = "",
	signupEnabled = true,
	showPharmacy = true,
	served = true,
} = Astro.props;

const siteUrl = "https://lucoze.com";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta
			name="keywords"
			content="healthcare software, clinic management, hospital management, patient records, appointment scheduling, medical billing, EHR, EMR, healthcare ERP, NABIDH, NPHIES, HL7 FHIR, ICD-10, clinic software UAE, hospital software Saudi Arabia, healthcare SaaS"
		/>

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:site_name" content="Lucoze" />
		<meta property="og:image" content={`${siteUrl}/images/og-image.png`} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />

		<!-- Canonical -->
		<link rel="canonical" href={canonical} />
		<link rel="alternate" hreflang="en" href={siteUrl} />
		<link rel="alternate" hreflang="x-default" href={siteUrl} />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
		<link rel="icon" type="image/png" href="/images/favicon.png" />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>

		<!-- Structured Data -->
		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "SoftwareApplication",
				name: "Lucoze",
				applicationCategory: "HealthApplication",
				operatingSystem: "Web",
				description:
					"Complete healthcare management platform for clinics, hospitals, and diagnostic centres. HL7 FHIR compatible, ICD-10 coding, multi-currency billing.",
				url: siteUrl,
				offers: {
					"@type": "AggregateOffer",
					lowPrice: "49",
					highPrice: "999",
					priceCurrency: "USD",
					offerCount: "4",
				},
				publisher: {
					"@type": "Organization",
					name: "Svasamm Research Pvt. Ltd.",
					url: "https://svasamm.com",
				},
				featureList:
					"Patient Management, Appointments, Clinical Procedures, Lab & Diagnostics, Billing, Inpatient Management, HR & Payroll, HL7 FHIR, ICD-10",
				availableCountry: [
					"AE",
					"SA",
					"QA",
					"BH",
					"KW",
					"OM",
					"SG",
					"MY",
					"ID",
					"TH",
					"PH",
					"AU",
					"NZ",
					"IN",
				],
			})}
		/>

		<slot name="head" />
	</head>
	<body data-region={regionSlug} data-served={String(served)}>
		<a href="#main" class="skip-link">Skip to main content</a>

		<Nav
			activeLink={activeLink}
			ctaPlan={ctaPlan}
			regionSlug={regionSlug}
			signupEnabled={signupEnabled}
			showPharmacy={showPharmacy}
		/>

		{!served && <NotServedBanner />}

		<main id="main">
			<slot />
		</main>

		<Footer regionSlug={regionSlug} showPharmacy={showPharmacy} />

		<CountrySelectorModal />

		<!-- Plausible Analytics (self-hosted, cookieless) — only load in production -->
		{!import.meta.env.DEV && (
			<script defer data-domain="lucoze.com" src="https://analytics.lucoze.com/js/script.js"></script>
		)}

		<script is:inline src="/js/region.js"></script>
		<script is:inline src="/js/main.js"></script>
		<script is:inline src="/js/tracker.js"></script>
	</body>
</html>
