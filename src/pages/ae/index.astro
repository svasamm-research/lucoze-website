---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
	regionSlug="ae"
	signupEnabled={true}
	served={true}
	title="Lucoze — Healthcare Management Software for Clinics & Hospitals — Middle East"
	description="Complete healthcare management platform for clinics and hospitals. Patient records, appointments, billing, inventory — all in one place. Start your free 14-day trial."
>
	<section class="hero">
		<div class="container hero__inner">
			<div class="hero__content">
				
				<h1>
					Healthcare<br />
					management,<br />
					<span>simplified.</span>
				</h1>
				<p class="hero__subtitle">
					The complete platform for clinics and hospitals — trusted across 4 regions.
					Patient records, appointments, billing, inventory, and compliance &mdash; everything your
					healthcare facility needs, in one place.
				</p>
				<div class="hero__stats">
					<div class="hero__stat">
						<div class="hero__stat-value">4</div>
						<div class="hero__stat-label">Tailored plans</div>
					</div>
					<div class="hero__stat">
						<div class="hero__stat-value">4</div>
						<div class="hero__stat-label">Regions served</div>
					</div>
					<div class="hero__stat">
						<div class="hero__stat-value">99.9%</div>
						<div class="hero__stat-label">Uptime SLA</div>
					</div>
				</div>
			</div>

			<div class="hero__visual fade-in">
				<div class="hero__dashboard">
					<div class="hero__dashboard-header">
						<span class="hero__dashboard-dot"></span>
						<span class="hero__dashboard-dot"></span>
						<span class="hero__dashboard-dot"></span>
						<span class="hero__dashboard-title">Lucoze Dashboard</span>
					</div>
					<div class="hero__dashboard-body">
						<div class="hero__dashboard-row">
							<div class="hero__mini-card">
								<div class="hero__mini-card-icon">📅</div>
								<div class="hero__mini-card-label">Today's Appointments</div>
								<div class="hero__mini-card-value hero__mini-card-value--primary">24</div>
							</div>
							<div class="hero__mini-card">
								<div class="hero__mini-card-icon">👥</div>
								<div class="hero__mini-card-label">Patients Seen</div>
								<div class="hero__mini-card-value hero__mini-card-value--success">18</div>
							</div>
						</div>
						<div class="hero__dashboard-row">
							<div class="hero__mini-card">
								<div class="hero__mini-card-icon">🏥</div>
								<div class="hero__mini-card-label">Beds Occupied</div>
								<div class="hero__mini-card-value hero__mini-card-value--info">32/50</div>
							</div>
							<div class="hero__mini-card">
								<div class="hero__mini-card-icon">🔬</div>
								<div class="hero__mini-card-label">Lab Reports Ready</div>
								<div class="hero__mini-card-value hero__mini-card-value--success">12</div>
							</div>
						</div>
						<div class="hero__dashboard-row hero__dashboard-row--full">
							<div class="hero__mini-card hero__mini-card--wide">
								<div class="hero__mini-card-label">Quick Actions</div>
								<div class="hero__quick-actions">
									<span class="hero__quick-btn">+ New Patient</span>
									<span class="hero__quick-btn">+ Appointment</span>
									<span class="hero__quick-btn">+ Encounter</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ Trust Bar (Compliance) ════════════════════════════════ -->
	<section class="trust-bar">
		<div class="container trust-bar__wrapper">
		<button class="trust-bar__arrow trust-bar__arrow--left" aria-label="Scroll left">&#8249;</button>
		<div class="trust-bar__inner">
			<div class="trust-bar__item" data-region-show="ae">
				<svg class="trust-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
				</svg>
				NABIDH Ready
			</div>
			<div class="trust-bar__item" data-region-show="ae">
				<svg class="trust-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
				</svg>
				NPHIES Compatible
			</div>
			<div class="trust-bar__item" data-region-show="in">
				<svg class="trust-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path>
					<path d="M22 4L12 14.01l-3-3"></path>
				</svg>
				ABDM Integrated
			</div>
			<div class="trust-bar__item" data-region-show="in">
				<svg class="trust-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
				</svg>
				ABHA Compatible
			</div>
			<div class="trust-bar__item" data-region-show="sg">
				<svg class="trust-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
				</svg>
				NEHR Ready
			</div>
			<div class="trust-bar__item">
				<svg class="trust-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<rect x="3" y="11" width="18" height="11" rx="2"></rect>
					<path d="M7 11V7a5 5 0 0110 0v4"></path>
				</svg>
				End-to-end encryption
			</div>
			<div class="trust-bar__item">
				<svg class="trust-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<circle cx="12" cy="12" r="10"></circle>
					<path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"></path>
				</svg>
				Data residency in your region
			</div>
			<div class="trust-bar__item" data-region-show="ae,sg,au,intl">
				<svg class="trust-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path>
					<path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"></path>
				</svg>
				HL7 FHIR
			</div>
			<div class="trust-bar__item">
				<svg class="trust-bar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path>
					<path d="M22 4L12 14.01l-3-3"></path>
				</svg>
				ICD-10 Coding
			</div>
		</div>
		<button class="trust-bar__arrow trust-bar__arrow--right" aria-label="Scroll right">&#8250;</button>
		</div>
	</section>

	<!-- ═══ Features ═════════════════════════════════════════════ -->
	<section class="section section--alt" id="features">
		<div class="container">
			<div class="section-header fade-in">
				<h2>Everything your facility needs</h2>
				<p>
					From small clinics to multi-specialty hospitals, Lucoze adapts to your practice and scales
					with your growth.
				</p>
			</div>
			<div class="features__grid">
				<div class="feature-card fade-in">
					<div class="feature-card__icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path>
							<circle cx="8.5" cy="7" r="4"></circle>
							<path d="M20 8v6M23 11h-6"></path>
						</svg>
					</div>
					<h3>Patient Management</h3>
					<p>
						Complete digital health records with demographics, medical history, vitals, and
						encounter notes. <span data-region-show="in">ABHA ID integration for Indian facilities.</span><span data-region-show="ae">NABIDH-compliant clinical documentation.</span><span data-region-show="sg,au,intl">HL7 FHIR-compliant record keeping.</span>
					</p>
				</div>
				<div class="feature-card fade-in fade-in-delay-1">
					<div class="feature-card__icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<rect x="3" y="4" width="18" height="18" rx="2"></rect>
							<path d="M16 2v4M8 2v4M3 10h18M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"
							></path>
						</svg>
					</div>
					<h3>Smart Scheduling</h3>
					<p>
						Practitioner-wise appointment scheduling with availability management, automated
						reminders, and walk-in queue handling.
					</p>
				</div>
				<div class="feature-card fade-in fade-in-delay-2">
					<div class="feature-card__icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path>
							<path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"></path>
						</svg>
					</div>
					<h3>Clinical Documentation</h3>
					<p>
						Structured encounter records with ICD-10 coding, prescription management, procedure
						tracking, and clinical decision support.
					</p>
				</div>
				<div class="feature-card fade-in">
					<div class="feature-card__icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
						</svg>
					</div>
					<h3>Lab &amp; Diagnostics</h3>
					<p>
						Complete laboratory workflow &mdash; test ordering, sample tracking, result entry with
						templates, and auto-generated reports.
					</p>
				</div>
				<div class="feature-card fade-in fade-in-delay-1">
					<div class="feature-card__icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<rect x="1" y="4" width="22" height="16" rx="2"></rect>
							<path d="M1 10h22"></path>
						</svg>
					</div>
					<h3>Billing &amp; Payments</h3>
					<p>
						GST-compliant invoicing, insurance and TPA processing, multi-currency support, and
						integrated payment collection.
					</p>
				</div>
				<div class="feature-card fade-in fade-in-delay-2">
					<div class="feature-card__icon">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path
								d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"
							></path>
							<path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12"></path>
						</svg>
					</div>
					<h3>Pharmacy &amp; Inventory</h3>
					<p>
						Medicine stock management with expiry tracking, automated reorder alerts, batch
						tracking, and dispensing records.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ Who It's For ══════════════════════════════════════════ -->
	<section class="section" id="who-its-for">
		<div class="container">
			<div class="section-header fade-in">
				<h2>Built for every type of healthcare</h2>
				<p>
					Whether you're running a small clinic or a hospital network, there's a Lucoze plan
					designed for you.
				</p>
			</div>
			<div class="audience__grid">
				<a
					href="/solutions-clinics"
					class="audience-card fade-in"
					style="text-decoration: none; color: inherit"
				>
					<div class="audience-card__icon"><svg viewBox="0 0 48 48" fill="none" stroke="#c15f3c" stroke-width="2" width="36" height="36"><rect x="8" y="12" width="32" height="28" rx="3"/><rect x="18" y="4" width="12" height="12" rx="2"/><path d="M24 8v4M22 10h4"/><path d="M16 24h6M26 24h6M16 32h6M26 32h6"/></svg></div>
					<h3>Clinics &amp; Polyclinics</h3>
					<p>
						Small to multi-doctor clinics. Appointments, encounters, prescriptions, and billing in
						one workflow.
					</p>
					<span class="audience-card__link">Learn more &rarr;</span>
				</a>
				<a
					href="/solutions-hospitals"
					class="audience-card fade-in fade-in-delay-1"
					style="text-decoration: none; color: inherit"
				>
					<div class="audience-card__icon"><svg viewBox="0 0 48 48" fill="none" stroke="#c15f3c" stroke-width="2" width="36" height="36"><rect x="6" y="8" width="36" height="34" rx="3"/><path d="M6 16h36M14 8V4M24 8V4M34 8V4"/><rect x="14" y="22" width="8" height="8" rx="1"/><rect x="26" y="22" width="8" height="8" rx="1"/><rect x="18" y="34" width="12" height="8" rx="1"/><path d="M24 22v-4M22 20h4"/></svg></div>
					<h3>Hospitals</h3>
					<p>
						Inpatient management, department isolation, ward management, OT scheduling, and full ERP
						with HR &amp; payroll.
					</p>
					<span class="audience-card__link">Learn more &rarr;</span>
				</a>
				</div>
		</div>
	</section>

	<!-- ═══ How It Works ══════════════════════════════════════════ -->
	<section class="section section--alt" id="how-it-works">
		<div class="container">
			<div class="section-header fade-in">
				<h2>Up and running in minutes</h2>
				<p>
					No downloads, no installations, no IT team required. Get started in four simple steps.
				</p>
			</div>
			<div class="steps__grid">
				<div class="step-card fade-in">
					<div class="step-card__number">1</div>
					<h3>Choose your plan</h3>
					<p>
						Pick the plan that matches your facility type and size. All plans include a 14-day free
						trial.
					</p>
				</div>
				<div class="step-card fade-in fade-in-delay-1">
					<div class="step-card__number">2</div>
					<h3>Set up your workspace</h3>
					<p>
						Your dedicated workspace is provisioned in seconds with your country's compliance and
						currency pre-configured.
					</p>
				</div>
				<div class="step-card fade-in fade-in-delay-2">
					<div class="step-card__number">3</div>
					<h3>Add your team</h3>
					<p>
						Invite doctors, nurses, receptionists, and staff. Role-based access ensures everyone
						sees only what they need.
					</p>
				</div>
				<div class="step-card fade-in fade-in-delay-3">
					<div class="step-card__number">4</div>
					<h3>Start seeing patients</h3>
					<p>
						Begin scheduling appointments, recording encounters, and generating bills from day one.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══ Pricing ══════════════════════════════════════════════ -->
	<section class="section" id="pricing">
		<div class="container">
			<div class="section-header fade-in">
				<h2>Simple, transparent pricing</h2>
				<p>No hidden fees, no per-user charges. Choose the plan that fits your facility.</p>
			</div>

			<!-- Pricing Controls -->
			<div class="pricing__controls fade-in">
				<button class="pricing__category-btn active" data-show="pricing-clinic" id="clinicPlanBtn">Clinic Plans</button>
				<div class="pricing__toggle">
					<span class="pricing__toggle-label active" data-billing="monthly">Monthly</span>
					<button class="pricing__toggle-switch" id="billingToggle" aria-label="Toggle annual billing"></button>
					<span class="pricing__toggle-label" data-billing="yearly">Yearly</span>
					<span class="pricing__save-badge">Save 15%</span>
				</div>
				<button class="pricing__category-btn" data-show="pricing-hospital" id="hospitalPlanBtn">Hospital Plans</button>
			</div>

			<!-- Clinic Plans (default visible) -->
			<div class="pricing__grid pricing__grid--2" id="pricing-clinic">
				<div class="pricing-card fade-in">
					<div class="pricing-card__badge"></div>
					<div class="pricing-card__name">Clinic</div>
					<div class="pricing-card__desc">Small clinic or polyclinic. Up to 5 doctors, basic billing.</div>
					<div class="pricing-card__price">
						<span class="pricing-card__currency">$</span>
						<span class="pricing-card__amount" data-monthly-in="3,999" data-yearly-in="3,399" data-monthly-ae="99" data-yearly-ae="84" data-monthly-sg="79" data-yearly-sg="67" data-monthly-au="149" data-yearly-au="127" data-monthly-intl="149" data-yearly-intl="127">99</span>
					</div>
					<div class="pricing-card__period">/month</div>
					<div class="pricing-card__annual">Billed monthly</div>
					<div class="pricing-card__divider"></div>
					<div class="pricing-card__features">
						<div class="pricing-card__feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>Patient management</div>
						<div class="pricing-card__feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>Appointments &amp; scheduling</div>
						<div class="pricing-card__feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>Encounters &amp; prescriptions</div>
						<div class="pricing-card__feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>Lab tests &amp; diagnostics</div>
						<div class="pricing-card__feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>Billing &amp; accounting</div>
					</div>
				</div>
				<div class="pricing-card pricing-card--featured fade-in fade-in-delay-1">
					<div class="pricing-card__badge">Most Popular</div>
					<div class="pricing-card__name">Clinic Plus</div>
					<div class="pricing-card__desc">Mid-size clinic or nursing home. Up to 15 doctors, 30 beds.</div>
					<div class="pricing-card__price">
						<span class="pricing-card__currency">$</span>
						<span class="pricing-card__amount" data-monthly-in="7,999" data-yearly-in="6,799" data-monthly-ae="199" data-yearly-ae="169" data-monthly-sg="149" data-yearly-sg="127" data-monthly-au="299" data-yearly-au="254" data-monthly-intl="299" data-yearly-intl="254">199</span>
					</div>
					<div class="pricing-card__period">/month</div>
					<div class="pricing-card__annual">Billed monthly</div>
					<div class="pricing-card__divider"></div>
					<div class="pricing-card__features">
						<div class="pricing-card__feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>Everything in Clinic</div>
						<div class="pricing-card__feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>Inventory &amp; pharmacy</div>
						<div class="pricing-card__feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>HR &amp; payroll</div>
						<div class="pricing-card__feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>Support desk</div>
					</div>
				</div>
				<div class="pricing-card fade-in fade-in-delay-2">
					<div class="pricing-card__badge">Enterprise</div>
					<div class="pricing-card__name">Clinic Enterprise</div>
					<div class="pricing-card__desc">Multi-branch clinics. Unlimited doctors, AI automation &amp; analytics.</div>
					<a href="/contact" class="btn btn--secondary btn--full" style="margin-top: var(--space-lg)">Contact Sales</a>
					<div class="pricing-card__divider"></div>
					<div class="pricing-card__features">
						<div class="pricing-card__feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>Everything in Clinic Plus</div>
						<div class="pricing-card__feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>Multiple branch support</div>
						<div class="pricing-card__feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>AI-powered analytics</div>
						<div class="pricing-card__feature"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>Workflow automation</div>
					</div>
				</div>
			</div>

			<!-- Hospital Plans (hidden by default) -->
			<div class="pricing__grid pricing__grid--2" id="pricing-hospital" style="display: none">
