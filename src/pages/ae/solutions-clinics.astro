---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
	regionSlug="ae"
	signupEnabled={true}
	served={true}
	title="Clinic & Polyclinic Management Software — Lucoze — Middle East"
	description="Lucoze for clinics and polyclinics — appointments, patient encounters, prescriptions, billing, and practice management in one simple platform."
	activeLink="solutions"
	ctaPlan="clinic"
>
	<section class="page-header">
		<div class="container">
			<h1>Clinic &amp; Polyclinic Management</h1>
			<p>Everything a modern clinic needs — from solo practices to multi-doctor polyclinics.</p>
		</div>
	</section>

	<section class="content-page">
		<div class="container" style="max-width: 900px">
			<div class="solution-hero fade-in">
				<p style="font-size: var(--font-size-lg); line-height: 1.7; color: var(--color-text-muted)">
					Running a clinic shouldn't mean drowning in paperwork. Lucoze brings together patient
					management, appointment scheduling, clinical encounters, prescriptions, and billing into a
					single, intuitive workflow that lets you focus on what matters most — your patients.
				</p>
			</div>

			<div class="about-values" style="margin: var(--space-2xl) 0">
				<div class="about-value fade-in">
					<div class="about-value__icon">
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="#c15f3c"
							stroke-width="2"
						>
							<circle cx="12" cy="12" r="10"></circle>
							<path d="M12 6v6l4 2"></path>
						</svg>
					</div>
					<h3>Smart Scheduling</h3>
					<p>
						Online appointment booking with practitioner availability, slot management, and
						automated reminders. Reduce no-shows by up to 40%.
					</p>
				</div>
				<div class="about-value fade-in fade-in-delay-1">
					<div class="about-value__icon">
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="#c15f3c"
							stroke-width="2"
						>
							<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path>
							<path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"></path>
						</svg>
					</div>
					<h3>Digital Patient Records</h3>
					<p>
						Complete patient history at your fingertips — demographics, vitals, encounters,
						prescriptions, lab results, and documents in one view.
					</p>
				</div>
				<div class="about-value fade-in fade-in-delay-2">
					<div class="about-value__icon">
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="#c15f3c"
							stroke-width="2"
						>
							<path d="M9 11l3 3L22 4"></path>
							<path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"></path>
						</svg>
					</div>
					<h3>Clinical Encounters</h3>
					<p>
						Structured encounter forms with diagnosis (ICD-10), symptoms, prescriptions, and
						clinical notes. Templates for faster documentation.
					</p>
				</div>
			</div>

			<h2 class="fade-in">Key Features for Clinics</h2>

			<div class="feature-list fade-in">
				<div class="feature-list__item">
					<h3>Prescription Management</h3>
					<p>
						Generate prescriptions with drug database integration, dosage suggestions, and
						print-ready formats. Track medication history across visits.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Billing &amp; Invoicing</h3>
					<p>
						Create invoices for consultations, procedures, and services. Support for GST (India),
						VAT (Middle East), and international tax formats. Accept online payments.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Basic Lab Integration</h3>
					<p>
						Order lab tests, receive results, and attach them to patient records. Upgrade to Clinic
						Plus for full in-house lab management.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Multi-Doctor Support</h3>
					<p>
						Manage multiple practitioners with individual schedules, consultation fees, and
						department assignments. Each doctor sees only their patients.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Reports &amp; Analytics</h3>
					<p>
						Track patient footfall, revenue, consultation patterns, and outstanding payments with
						built-in dashboards and exportable reports.
					</p>
				</div>
				<div class="feature-list__item" data-region-show="in">
					<h3>ABDM / ABHA Ready</h3>
					<p>
						For Indian clinics — integrate with Ayushman Bharat Digital Mission, verify ABHA IDs,
						and share health records on the national network.
					</p>
				</div>
			</div>
				<div class="feature-list__item" data-region-show="ae">
					<h3>NABIDH / NPHIES Ready</h3>
					<p>
						For GCC clinics — connect to NABIDH (Dubai) and NPHIES (Saudi) health
						information exchanges for regulatory compliance.
					</p>
				</div>

			<h2 class="fade-in">Plans for Clinics</h2>
			<div class="solution-plans fade-in">
				<div class="solution-plan">
					<h3>Clinic</h3>
					<p>Small clinic or polyclinic. Up to 5 doctors, basic billing.</p>
					<div class="solution-plan__price"><span class="pricing-card__currency">$</span><span class="pricing-card__amount" data-monthly-in="3,999" data-monthly-ae="99" data-monthly-sg="79" data-monthly-au="149" data-monthly-intl="149">99</span>/mo</div>
					<a href="/signup?plan=clinic" class="btn btn--primary">Start Free Trial</a>
				</div>
				<div class="solution-plan solution-plan--featured">
					<h3>Clinic Plus</h3>
					<p>Mid-size clinic or nursing home. Up to 15 doctors, 30 beds, full lab &amp; IPD.</p>
					<div class="solution-plan__price"><span class="pricing-card__currency">$</span><span class="pricing-card__amount" data-monthly-in="7,999" data-monthly-ae="199" data-monthly-sg="149" data-monthly-au="299" data-monthly-intl="299">199</span>/mo</div>
					<a href="/signup?plan=Clinic Plus" class="btn btn--primary">Start Free Trial</a>
				</div>
				<div class="solution-plan">
					<h3>Clinic Enterprise</h3>
					<p>Multi-branch clinics. Unlimited doctors, branches, AI-powered automation &amp; analytics.</p>
					<div class="solution-plan__price"><span class="pricing-card__currency">$</span><span class="pricing-card__amount" data-monthly-in="14,999" data-monthly-ae="399" data-monthly-sg="299" data-monthly-au="499" data-monthly-intl="499">399</span>/mo</div>
					<a href="/contact" class="btn btn--secondary">Contact Sales</a>
				</div>
			</div></section>

	<section class="cta">
		<div class="container">
			<h2>Ready to modernise your clinic?</h2>
			<p>Start your free 14-day trial today. No credit card required.</p>
			<a href="/signup?plan=clinic" class="btn btn--primary btn--lg">Start Your Free Trial</a>
		</div>
	</section>
</BaseLayout>
