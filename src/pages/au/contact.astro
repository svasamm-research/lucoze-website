---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
	regionSlug="au"
	signupEnabled={true}
	served={true}
	title="Contact Us — Lucoze — Australia & New Zealand"
	description="Get in touch with the Lucoze team for demos, pricing, and support."
	activeLink="contact"
>
	<section class="page-header">
		<div class="container">
			<h1>Contact Us</h1>
			<p>Have a question or need help? We'd love to hear from you.</p>
		</div>
	</section>

	<section class="signup">
		<div class="container signup__inner">
			<!-- Left Column -->
			<div class="signup__info">
				<h2>Get in touch</h2>
				<p>
					Whether you have questions about our plans, need a demo, or want to discuss a partnership,
					our team is ready to help.
				</p>

				<ul class="signup__benefits">
					<li>
						<span class="signup__benefit-icon">
							<svg
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="#c15f3c"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path
									d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
								></path>
								<path d="M22 6l-10 7L2 6"></path>
							</svg>
						</span>
						<span><strong>Email:</strong> info@lucoze.com</span>
					</li>
					<li>
						<span class="signup__benefit-icon">
							<svg
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="#c15f3c"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path>
								<circle cx="12" cy="10" r="3"></circle>
							</svg>
						</span>
						<span><strong>Location:</strong> Bengaluru, India</span>
					</li>
					<li>
						<span class="signup__benefit-icon">
							<svg
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="#c15f3c"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<circle cx="12" cy="12" r="10"></circle>
								<path d="M12 6v6l4 2"></path>
							</svg>
						</span>
						<span><strong>Response time:</strong> Within 24 hours</span>
					</li>
					<li>
						<span class="signup__benefit-icon">
							<svg
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="#c15f3c"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path
									d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"
								></path>
							</svg>
						</span>
						<span><strong>Support:</strong> support@lucoze.com</span>
					</li>
				</ul>
			</div>

			<!-- Right Column -->
			<div class="signup__form-card">
				<h2>Send us a message</h2>

				<div id="contactAlert" class="alert"></div>

				<form id="contactForm">
					<div class="form-group">
						<label for="contactName">Your Name</label>
						<input
							type="text"
							class="form-control"
							id="contactName"
							name="name"
							placeholder="Full name"
							required
						/>
					</div>

					<div class="form-group">
						<label for="contactEmail">Email</label>
						<input
							type="email"
							class="form-control"
							id="contactEmail"
							name="email"
							placeholder="you@example.com"
							required
						/>
					</div>

					<div class="form-group">
						<label for="contactPhone"
							>Phone
							<span style="color: var(--color-text-muted); font-weight: 400">(optional)</span
							></label
						>
						<input
							type="tel"
							class="form-control"
							id="contactPhone"
							name="phone"
							placeholder="+1 234 567 8900"
						/>
					</div>

					<div class="form-group">
						<label for="contactCountry">Country</label>
						<select class="form-control" id="contactCountry" name="contact_country">
							<option value="" disabled selected>Select your country</option>
							<optgroup label="Middle East">
								<option value="United Arab Emirates">🇦🇪 United Arab Emirates</option>
								<option value="Saudi Arabia">🇸🇦 Saudi Arabia</option>
								<option value="Qatar">🇶🇦 Qatar</option>
								<option value="Bahrain">🇧🇭 Bahrain</option>
								<option value="Kuwait">🇰🇼 Kuwait</option>
								<option value="Oman">🇴🇲 Oman</option>
							</optgroup>
							<optgroup label="Southeast Asia">
								<option value="Singapore">🇸🇬 Singapore</option>
								<option value="Malaysia">🇲🇾 Malaysia</option>
								<option value="Indonesia">🇮🇩 Indonesia</option>
								<option value="Thailand">🇹🇭 Thailand</option>
								<option value="Philippines">🇵🇭 Philippines</option>
							</optgroup>
							<optgroup label="India">
								<option value="India">🇮🇳 India</option>
							</optgroup>
							<optgroup label="Australia & NZ">
								<option value="Australia">🇦🇺 Australia</option>
								<option value="New Zealand">🇳🇿 New Zealand</option>
							</optgroup>
							<optgroup label="Other">
								<option value="Other">🌍 Other Country</option>
							</optgroup>
						</select>
					</div>

					<div class="form-group">
						<label for="contactSubject">Subject</label>
						<select class="form-control" id="contactSubject" name="subject" required>
							<option value="" disabled selected>Select a topic</option>
							<option value="General Inquiry">General Inquiry</option>

							<option value="Pricing & Plans">Pricing &amp; Plans</option>
							<option value="Request a Demo">Request a Demo</option>
							<option value="Technical Support">Technical Support</option>
							<option value="Partnership">Partnership</option>
							<option value="Other">Other</option>
						</select>
					</div>

					<div class="form-group">
						<label for="contactMessage">Message</label>
						<textarea
							class="form-control"
							id="contactMessage"
							name="message"
							rows="5"
							placeholder="Tell us how we can help..."
							required></textarea>
					</div>

					<button type="submit" class="btn btn--primary btn--full btn--lg" id="contactBtn">
						Send Message
					</button>
				</form>
			</div>
		</div>
	</section>
</BaseLayout>
