---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
	regionSlug="au"
	signupEnabled={true}
	showPharmacy={true}
	served={true}
	title="Diagnostic Centre Software — Lucoze — Australia & New Zealand"
	description="Lucoze for diagnostic centres — lab workflow, sample management, result entry, quality control, and multi-branch operations."
	activeLink="solutions"
>
	<section class="page-header">
		<div class="container">
			<h1>Diagnostic Centre &amp; Lab Management</h1>
			<p>From sample collection to report delivery — streamline your entire lab workflow.</p>
		</div>
	</section>

	<section class="content-page">
		<div class="container" style="max-width: 900px">
			<div class="solution-hero fade-in">
				<p style="font-size: var(--font-size-lg); line-height: 1.7; color: var(--color-text-muted)">
					Diagnostic centres and pathology labs handle thousands of samples daily. Lucoze eliminates
					manual tracking with barcode-based sample management, structured result entry templates,
					automated report generation, and quality control workflows — whether you run a single lab
					or a network of collection centres.
				</p>
			</div>

			<div class="about-values" style="margin: var(--space-2xl) 0">
				<div class="about-value fade-in">
					<div class="about-value__icon">
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="#c15f3c"
							stroke-width="2"
						>
							<rect x="3" y="3" width="18" height="18" rx="2"></rect>
							<path d="M3 9h18M9 21V9"></path>
						</svg>
					</div>
					<h3>Sample Management</h3>
					<p>
						Barcode generation, sample collection tracking, tube labelling, and chain-of-custody
						from collection point to analyser.
					</p>
				</div>
				<div class="about-value fade-in fade-in-delay-1">
					<div class="about-value__icon">
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="#c15f3c"
							stroke-width="2"
						>
							<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path>
							<path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"></path>
						</svg>
					</div>
					<h3>Result Templates</h3>
					<p>
						Pre-configured templates for CBC, LFT, RFT, thyroid panels, and hundreds more. Normal
						ranges, units, and flags built in.
					</p>
				</div>
				<div class="about-value fade-in fade-in-delay-2">
					<div class="about-value__icon">
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="#c15f3c"
							stroke-width="2"
						>
							<path d="M22 11.08V12a10 10 0 11-5.93-9.14"></path>
							<path d="M22 4L12 14.01l-3-3"></path>
						</svg>
					</div>
					<h3>Quality Control</h3>
					<p>
						Internal QC tracking, Levey-Jennings charts, Westgard rules, and external quality
						assessment (EQA) management.
					</p>
				</div>
			</div>

			<h2 class="fade-in">Key Features for Diagnostic Centres</h2>

			<div class="feature-list fade-in">
				<div class="feature-list__item">
					<h3>Test Catalogue Management</h3>
					<p>
						Configure test panels, individual tests, profiles, and packages. Set pricing per test,
						department-wise routing, and turnaround time targets.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Multi-Branch Support</h3>
					<p>
						Manage collection centres across the city with centralised processing. Track samples
						across locations with real-time status updates.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Automated Report Generation</h3>
					<p>
						Results entered once, formatted into professional PDF reports with your branding, doctor
						sign-off, and critical value highlighting.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Patient Portal</h3>
					<p>
						Patients can view and download their reports online. Reduce front-desk queues and phone
						calls for report collection.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Referring Doctor Management</h3>
					<p>
						Track referrals, share results with referring doctors, and manage commission or referral
						fee structures.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Billing &amp; Accounting</h3>
					<p>
						Itemised billing, credit accounts for corporates and hospitals, outstanding tracking,
						and GST/VAT compliant invoicing.
					</p>
				</div>
			</div>

			<h2 class="fade-in">Plans for Diagnostic Centres</h2>
			<div class="solution-plans fade-in">
				<div class="solution-plan">
					<h3>Pathology</h3>
					<p>Single lab. Lab workflow, sample management, result entry.</p>
					<div class="solution-plan__price">&#x20B9;2,999 / $49 per month</div>
					<a href="/contact?subject=Pathology" class="btn btn--secondary">Contact Us</a>
				</div>
				<div class="solution-plan">
					<h3>Pathology Plus</h3>
					<p>Lab + patient management. Full records, appointments, billing.</p>
					<div class="solution-plan__price">&#x20B9;4,999 / $79 per month</div>
					<a href="/contact?subject=Pathology Plus" class="btn btn--secondary">Contact Us</a>
				</div>
				<div class="solution-plan solution-plan--featured">
					<h3>Pathology Network</h3>
					<p>Multi-branch diagnostics. Up to 10 branches, centralised processing.</p>
					<div class="solution-plan__price">&#x20B9;9,999 / $169 per month</div>
					<a href="/contact?subject=Pathology Network" class="btn btn--secondary">Contact Us</a>
				</div>
			</div>
		</div>
	</section>

	<section class="cta">
		<div class="container">
			<h2>Modernise your diagnostic centre</h2>
			<p>Join labs across the world that trust Lucoze. Get in touch to get started.</p>
			<a href="/contact?subject=Pathology" class="btn btn--primary btn--lg">Contact Us</a>
		</div>
	</section>
</BaseLayout>
