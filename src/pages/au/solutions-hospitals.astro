---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
	regionSlug="au"
	signupEnabled={true}
	served={true}
	title="Hospital Management Software — Lucoze — Australia & New Zealand"
	description="Lucoze for hospitals — inpatient management, department isolation, OT scheduling, ward management, HR, payroll, and complete hospital ERP."
	activeLink="solutions"
	ctaPlan="hospital"
>
	<section class="page-header">
		<div class="container">
			<h1>Hospital Management</h1>
			<p>
				Enterprise-grade hospital ERP at a fraction of the cost. From 30-bed nursing homes to 500+
				bed hospitals.
			</p>
		</div>
	</section>

	<section class="content-page">
		<div class="container" style="max-width: 900px">
			<div class="solution-hero fade-in">
				<p style="font-size: var(--font-size-lg); line-height: 1.7; color: var(--color-text-muted)">
					Hospitals need more than just patient records. They need full operational control —
					inpatient management, department-level isolation, ward and bed tracking, OT scheduling,
					insurance and TPA processing, HR and payroll, procurement, and financial reporting. Lucoze
					delivers all of this in one unified platform.
				</p>
			</div>

			<div class="about-values" style="margin: var(--space-2xl) 0">
				<div class="about-value fade-in">
					<div class="about-value__icon">
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="#c15f3c"
							stroke-width="2"
						>
							<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path>
							<path d="M9 22V12h6v10"></path>
						</svg>
					</div>
					<h3>Inpatient Management</h3>
					<p>
						Admission, bed allocation, ward transfers, discharge summaries, and real-time bed
						availability dashboards. Track every patient journey.
					</p>
				</div>
				<div class="about-value fade-in fade-in-delay-1">
					<div class="about-value__icon">
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="#c15f3c"
							stroke-width="2"
						>
							<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path>
							<circle cx="9" cy="7" r="4"></circle>
							<path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"></path>
						</svg>
					</div>
					<h3>Department Isolation</h3>
					<p>
						Each department head sees only their patients, staff, and operations. Hospital admin
						sees everything. Built on role-based access control.
					</p>
				</div>
				<div class="about-value fade-in fade-in-delay-2">
					<div class="about-value__icon">
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="#c15f3c"
							stroke-width="2"
						>
							<rect x="2" y="3" width="20" height="14" rx="2"></rect>
							<path d="M8 21h8M12 17v4"></path>
						</svg>
					</div>
					<h3>OT &amp; Procedure Scheduling</h3>
					<p>
						Schedule surgeries, track OT availability, manage surgical teams, and document
						procedures with structured clinical notes.
					</p>
				</div>
			</div>

			<h2 class="fade-in">Key Features for Hospitals</h2>

			<div class="feature-list fade-in">
				<div class="feature-list__item">
					<h3>Ward &amp; Bed Management</h3>
					<p>
						Visual bed maps, automatic availability tracking, ward-level nurse assignments, and
						housekeeping status for every service unit.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Insurance &amp; TPA Processing</h3>
					<p>
						Pre-authorization workflows, claim submission, TPA coordination, and settlement
						tracking. Support for multiple insurance providers per patient.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>HR &amp; Payroll</h3>
					<p>
						Full employee lifecycle — recruitment, attendance, leave management, shift scheduling,
						payroll processing, and statutory compliance.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Procurement &amp; Inventory</h3>
					<p>
						Purchase orders, vendor management, stock tracking across departments, reorder levels,
						expiry alerts, and consumption analytics.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Financial Management</h3>
					<p>
						General ledger, accounts payable/receivable, cost centre accounting by department,
						budgets, and statutory financial reports.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Quality &amp; Compliance</h3>
					<p>
						Quality inspections, incident reporting, corrective actions, and audit trails. Built to
						support NABH and JCI accreditation workflows.
					</p>
				</div>
			</div>

			<h2 class="fade-in">Plans for Hospitals</h2>
			<div class="solution-plans fade-in">
				<div class="solution-plan">
					<h3>Hospital</h3>
					<p>Hospitals with departments. Up to 50 doctors, 100 beds, full ERP.</p>
					<div class="solution-plan__price">
						<span class="pricing-card__currency">$</span><span
							class="pricing-card__amount"
							data-monthly-in="14,999"
							data-monthly-ae="399"
							data-monthly-sg="299"
							data-monthly-au="599"
							data-monthly-intl="599">399</span
						>/mo
					</div>
					<a href="/signup?plan=hospital" class="btn btn--primary">Start Free Trial</a>
				</div>
				<div class="solution-plan solution-plan--featured">
					<h3>Hospital Pro</h3>
					<p>Large hospitals &amp; networks. Unlimited doctors, beds, users, multi-department.</p>
					<div class="solution-plan__price">
						<span class="pricing-card__currency">$</span><span
							class="pricing-card__amount"
							data-monthly-in="29,999"
							data-monthly-ae="799"
							data-monthly-sg="499"
							data-monthly-au="999"
							data-monthly-intl="999">799</span
						>/mo
					</div>
					<a href="/signup?plan=Hospital Pro" class="btn btn--primary">Start Free Trial</a>
				</div>
				<div class="solution-plan">
					<h3>Hospital Enterprise</h3>
					<p>
						Hospital chains &amp; networks. Unlimited everything, AI diagnostics, automation,
						dedicated support.
					</p>
					<div
						class="solution-plan__price"
						style="color: var(--color-text-muted); font-size: var(--font-size-sm)"
					>
						Custom pricing
					</div>
					<a href="/contact" class="btn btn--secondary">Contact Sales</a>
				</div>
			</div>
		</div>

		<section class="cta">
			<div class="container">
				<h2>Enterprise power, startup simplicity</h2>
				<p>
					Get your hospital running on Lucoze in under an hour. Free 14-day trial, no credit card
					required.
				</p>
				<a href="/signup?plan=hospital" class="btn btn--primary btn--lg">Start Your Free Trial</a>
			</div>
		</section>
	</section>
</BaseLayout>
