---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
	regionSlug="au"
	signupEnabled={true}
	showPharmacy={true}
	served={true}
	title="Pharmacy Management Software — Lucoze — Australia & New Zealand"
	description="Lucoze for pharmacies — dispensing, inventory, billing, procurement, and multi-store management."
	activeLink="solutions"
>
	<section class="page-header">
		<div class="container">
			<h1>Pharmacy Management</h1>
			<p>Complete pharmacy operations — from dispensing to inventory to multi-store management.</p>
		</div>
	</section>

	<section class="content-page">
		<div class="container" style="max-width: 900px">
			<div class="solution-hero fade-in">
				<p style="font-size: var(--font-size-lg); line-height: 1.7; color: var(--color-text-muted)">
					Modern pharmacies need more than a billing counter. They need real-time stock visibility,
					automated reorder alerts, expiry tracking, supplier management, and GST-compliant
					invoicing. Lucoze gives independent pharmacies and chains the tools to run efficiently and
					profitably.
				</p>
			</div>

			<div class="about-values" style="margin: var(--space-2xl) 0">
				<div class="about-value fade-in">
					<div class="about-value__icon">
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="#c15f3c"
							stroke-width="2"
						>
							<path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"></path>
							<path d="M3 6h18M16 10a4 4 0 01-8 0"></path>
						</svg>
					</div>
					<h3>Inventory Control</h3>
					<p>
						Real-time stock levels across stores. Batch tracking, expiry alerts 90/60/30 days out,
						and automated reorder points based on sales velocity.
					</p>
				</div>
				<div class="about-value fade-in fade-in-delay-1">
					<div class="about-value__icon">
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="#c15f3c"
							stroke-width="2"
						>
							<rect x="1" y="4" width="22" height="16" rx="2"></rect>
							<path d="M1 10h22"></path>
						</svg>
					</div>
					<h3>Fast Billing</h3>
					<p>
						Scan barcodes, auto-populate drug details, apply discounts, and generate GST/VAT
						invoices in seconds. Supports cash, card, and UPI payments.
					</p>
				</div>
				<div class="about-value fade-in fade-in-delay-2">
					<div class="about-value__icon">
						<svg
							width="32"
							height="32"
							viewBox="0 0 24 24"
							fill="none"
							stroke="#c15f3c"
							stroke-width="2"
						>
							<circle cx="12" cy="12" r="10"></circle>
							<path d="M16 8l-8 8M8 8l8 8"></path>
						</svg>
					</div>
					<h3>Expiry Management</h3>
					<p>
						Never sell expired stock again. Automatic alerts, near-expiry reports, and
						return-to-vendor workflows for expiring inventory.
					</p>
				</div>
			</div>

			<h2 class="fade-in">Key Features for Pharmacies</h2>

			<div class="feature-list fade-in">
				<div class="feature-list__item">
					<h3>Drug Database</h3>
					<p>
						Pre-loaded with thousands of medicines (generic and brand names), formulations,
						schedules, and substitutes. Search by name, salt, or barcode.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Purchase &amp; Supplier Management</h3>
					<p>
						Create purchase orders, track deliveries, manage supplier pricing and credit terms, and
						reconcile purchase invoices automatically.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Multi-Store Operations</h3>
					<p>
						Central procurement, inter-store transfers, store-wise P&amp;L, and consolidated
						reporting for pharmacy chains with up to 10 locations.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Returns Management</h3>
					<p>
						Handle customer returns and vendor returns with full audit trails. Credit notes and
						replacement workflows built in.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>GST &amp; Tax Compliance</h3>
					<p>
						Automatic GST calculation by drug schedule (5%, 12%, 18%), GSTR filing support, and HSN
						code mapping. International VAT supported.
					</p>
				</div>
				<div class="feature-list__item">
					<h3>Sales Analytics</h3>
					<p>
						Track bestsellers, slow movers, profit margins by product, daily/weekly/monthly sales
						trends, and customer purchase history.
					</p>
				</div>
			</div>

			<h2 class="fade-in">Plans for Pharmacies</h2>
			<div class="solution-plans fade-in">
				<div class="solution-plan">
					<h3>Pharmacy</h3>
					<p>Single medicine shop. Dispensing, inventory, billing.</p>
					<div class="solution-plan__price">&#x20B9;1,999 / $39 per month</div>
					<a href="/contact?subject=Pharmacy" class="btn btn--secondary">Contact Us</a>
				</div>
				<div class="solution-plan solution-plan--featured">
					<h3>Pharmacy Chain</h3>
					<p>Multi-store pharmacy. Up to 10 stores, central procurement.</p>
					<div class="solution-plan__price">&#x20B9;7,999 / $129 per month</div>
					<a href="/contact?subject=Pharmacy Chain" class="btn btn--secondary">Contact Us</a>
				</div>
			</div>
		</div>
	</section>

	<section class="cta">
		<div class="container">
			<h2>Run your pharmacy smarter</h2>
			<p>Ready to streamline your pharmacy operations? Get in touch to get started.</p>
			<a href="/contact?subject=Pharmacy" class="btn btn--primary btn--lg">Contact Us</a>
		</div>
	</section>
</BaseLayout>
