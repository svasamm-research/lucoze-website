---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
	regionSlug="in"
	signupEnabled={true}
	showPharmacy={true}
	served={true}
	title="Sign Up — Lucoze Healthcare Management — India"
	description="Start your free 14-day trial of Lucoze healthcare management. No credit card required."
	activeLink=""
>
	<section class="signup">
		<div class="container signup__inner">
			<!-- Left Column -->
			<div class="signup__info">
				<h1>Start your free trial</h1>
				<p>Get your healthcare workspace ready in 60 seconds. No credit card required.</p>

				<ul class="signup__benefits">
					<li>
						<span class="signup__benefit-icon">
							<svg
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="#c15f3c"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<circle cx="12" cy="12" r="10"></circle>
								<path d="M9 12l2 2 4-4"></path>
							</svg>
						</span>
						<span>14-day full-featured trial</span>
					</li>
					<li>
						<span class="signup__benefit-icon">
							<svg
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="#c15f3c"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<rect x="1" y="4" width="22" height="16" rx="2"></rect>
								<line x1="1" y1="10" x2="23" y2="10"></line>
								<line x1="6" y1="15" x2="8" y2="15"></line>
								<line x1="15" y1="12" x2="19" y2="18"></line>
								<line x1="19" y1="12" x2="15" y2="18"></line>
							</svg>
						</span>
						<span>No credit card required</span>
					</li>
					<li>
						<span class="signup__benefit-icon">
							<svg
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="#c15f3c"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
							</svg>
						</span>
						<span>Setup in under 60 seconds</span>
					</li>
					<li>
						<span class="signup__benefit-icon">
							<svg
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="#c15f3c"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<circle cx="12" cy="12" r="10"></circle>
								<line x1="2" y1="12" x2="22" y2="12"></line>
								<path
									d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
								></path>
							</svg>
						</span>
						<span>Data stored in your region</span>
					</li>
					<li>
						<span class="signup__benefit-icon">
							<svg
								width="24"
								height="24"
								viewBox="0 0 24 24"
								fill="none"
								stroke="#c15f3c"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<circle cx="12" cy="12" r="10"></circle>
								<line x1="15" y1="9" x2="9" y2="15"></line>
								<line x1="9" y1="9" x2="15" y2="15"></line>
							</svg>
						</span>
						<span>Cancel anytime</span>
					</li>
				</ul>
			</div>

			<!-- Right Column -->
			<div class="signup__form-card">
				<h2>Create your workspace</h2>

				<div id="signupAlert" class="alert"></div>

				<form id="signupForm">
					<!-- Plan Selector -->
					<div class="plan-selector">
						<label class="plan-option" data-plan="Clinic" data-category="clinic">
							<input type="radio" name="plan" value="Clinic" checked />
							<span class="plan-option__name">Clinic</span>
							<span class="plan-option__price">&#x20B9;3,999/$69/mo</span>
						</label>
						<label class="plan-option" data-plan="Clinic Plus" data-category="clinic">
							<input type="radio" name="plan" value="Clinic Plus" />
							<span class="plan-option__name">Clinic Plus</span>
							<span class="plan-option__price">&#x20B9;7,999/$129/mo</span>
						</label>
						<label class="plan-option" data-plan="Hospital" data-category="clinic">
							<input type="radio" name="plan" value="Hospital" />
							<span class="plan-option__name">Hospital</span>
							<span class="plan-option__price">&#x20B9;14,999/$249/mo</span>
						</label>
						<label class="plan-option" data-plan="Hospital Pro" data-category="clinic">
							<input type="radio" name="plan" value="Hospital Pro" />
							<span class="plan-option__name">Hospital Pro</span>
							<span class="plan-option__price">&#x20B9;29,999/$499/mo</span>
						</label>
					</div>

					<p
						style="
								font-size: var(--font-size-xs);
								color: var(--color-text-muted);
								margin-bottom: var(--space-md);
							"
					>
						Looking for Diagnostics or Pharmacy plans?
						<a href="/contact" style="color: var(--color-primary)">Contact our team</a> for a personalised
						setup.
					</p>

					<!-- Facility Name -->
					<div class="form-group">
						<label for="facilityName">Facility Name</label>
						<input
							type="text"
							class="form-control"
							id="facilityName"
							name="facility_name"
							placeholder="e.g. City Health Clinic"
							required
						/>
					</div>

					<!-- Your Name -->
					<div class="form-group">
						<label for="customerName">Your Name</label>
						<input
							type="text"
							class="form-control"
							id="customerName"
							name="customer_name"
							placeholder="Full name"
							required
						/>
					</div>

					<!-- Email & Phone -->
					<div class="form-row">
						<div class="form-group">
							<label for="customerEmail">Email</label>
							<input
								type="email"
								class="form-control"
								id="customerEmail"
								name="email"
								placeholder="you@example.com"
								required
							/>
						</div>
						<div class="form-group">
							<label for="customerPhone"
								>Phone
								<span style="color: var(--color-text-muted); font-weight: 400">(optional)</span
								></label
							>
							<input
								type="tel"
								class="form-control"
								id="customerPhone"
								name="phone"
								placeholder="+91 98765 43210"
							/>
						</div>
					</div>

					<!-- Country -->
					<div class="form-group">
						<label for="customerCountry">Country</label>
						<select class="form-control" id="customerCountry" name="country" required>
							<option value="" disabled selected>Select your country</option>
							<option value="India">India</option>
							<option value="United Arab Emirates">United Arab Emirates</option>
							<option value="Saudi Arabia">Saudi Arabia</option>
							<option value="Qatar">Qatar</option>
							<option value="Bahrain">Bahrain</option>
							<option value="Kuwait">Kuwait</option>
							<option value="Oman">Oman</option>
							<option value="Singapore">Singapore</option>
							<option value="Malaysia">Malaysia</option>
							<option value="Indonesia">Indonesia</option>
							<option value="Thailand">Thailand</option>
							<option value="Philippines">Philippines</option>
							<option value="United States">United States</option>
							<option value="Canada">Canada</option>
							<option value="United Kingdom">United Kingdom</option>
							<option value="Germany">Germany</option>
							<option value="France">France</option>
							<option value="Australia">Australia</option>
							<option value="New Zealand">New Zealand</option>
							<option value="South Africa">South Africa</option>
							<option value="Nigeria">Nigeria</option>
							<option value="Kenya">Kenya</option>
						</select>
					</div>

					<!-- Submit -->
					<button type="submit" class="btn btn--primary btn--full btn--lg" id="signupBtn">
						Start Your Free Trial
					</button>

					<p
						style="
								text-align: center;
								font-size: var(--font-size-xs);
								color: var(--color-text-muted);
								margin-top: var(--space-md);
							"
					>
						By signing up, you agree to our <a href="/terms">Terms of Service</a> and
						<a href="/privacy">Privacy Policy</a>.
					</p>
				</form>
			</div>
		</div>
	</section>

	<!-- Footer -->
</BaseLayout>
